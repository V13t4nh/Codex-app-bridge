# Codex Desktop must be launched with --remote-debugging-port=9222
CODEX_CDP_URL=http://127.0.0.1:9222

# Optional. If unset, Telegram is disabled and local E2E still works.
TELEGRAM_BOT_TOKEN=

# Optional comma-separated Telegram user IDs allowed to use the bot.
TELEGRAM_ALLOWED_USER_IDS=

# Optional. Only read from env if future integrations need it. Never hardcode.
OPENAI_API_KEY=

# Optional: debug, info, warn, error
LOG_LEVEL=info

# Optional. When set, the bridge clicks this Codex project/workspace before sending.
CODEX_WORKSPACE_NAME=

# Optional: current or new. current uses the current chat in CODEX_WORKSPACE_NAME; new starts a new chat for each prompt.
CODEX_CHAT_MODE=current
